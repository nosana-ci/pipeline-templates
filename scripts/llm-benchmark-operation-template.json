{
  "id": "benchmark",
  "type": "container/run",
  "args": {
    "image": "nosana/llm-benchmark:0.0.2",
    "gpu": true,
    "env": {
      "BASE_URL": "__BASE_URL__",
      "DURATION": "100",
      "CONCURRENT_USERS": "1",
      "WARMUP_REQUEST_TIMEOUT": "300"
    }
  },
  "execution": {
    "group": "llm-pair"
  }
}
