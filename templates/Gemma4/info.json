      "id": "e2b",
      "name": "E2B Model",
      "description": "Gemma 4 E2B edge model (2.3B effective parameters, 128K context, Text + Image)",
      "job_definition": "job-definition-e2b.json",
      "metrics_schema": [
        {
          "key": "gemma4-e2b__tokens_per_second",
          "input": "\"users_1_tokens_per_second_mean\":(-?[\\d.]+)",
          "type": "float",
          "expiry": "5d",
          "processor": "regex_parser",
          "defaultValue": null
        },
