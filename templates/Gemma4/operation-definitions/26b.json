[
  {
    "id": "Gemma4-26b",
    "type": "container/run",
    "args": {
      "gpu": true,
      "image": "docker.io/ollama/ollama:0.20.0",
      "expose": [
        {
          "port": 11434,
          "health_checks": [
            {
              "type": "http",
              "path": "/api/tags",
              "method": "GET",
              "expected_status": 200,
              "continuous": false
            }
          ]
        }
      ],
      "resources": [
        {
          "type": "Ollama",
          "model": "gemma4:26b"
        }
      ]
    },
    "execution": {
      "group": "llm-pair",
      "depends_on": [
        "benchmark"
      ],
      "stop_if_dependent_stops": true
    }
  },
  {
    "id": "benchmark",
    "type": "container/run",
    "args": {
      "image": "nosana/llm-benchmark:0.0.2",
      "gpu": true,
      "env": {
        "BASE_URL": "http://%%ops.Gemma4-26b.host%%:11434",
        "DURATION": "100",
        "CONCURRENT_USERS": "1",
        "WARMUP_REQUEST_TIMEOUT": "300"
      }
    },
    "execution": {
      "group": "llm-pair"
    },
    "results": {
      "gemma4-26b__tokens_per_second": "\"users_1_tokens_per_second_mean\":(-?[\\d.]+)",
      "gemma4-26b__gpu_wattage_avg": "\"users_1_gpu_wattage_avg\":(-?[\\d.]+)",
      "gemma4-26b__gpu_temperature_avg": "\"users_1_gpu_temperature_avg\":(-?[\\d.]+)"
    }
  }
]
