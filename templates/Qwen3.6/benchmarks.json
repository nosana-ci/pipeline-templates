[
  {
    "variants": [
      "27b",
      "35b-a3b"
    ],
    "timeoutSeconds": 1800,
    "metrics": [
      {
        "key": "tokens_per_second",
        "type": "float",
        "expiry": "5d",
        "processor": "results_selector",
        "defaultValue": null,
        "input": "tokens_per_second"
      },
      {
        "key": "gpu_wattage_avg",
        "type": "float",
        "expiry": "5d",
        "processor": "results_selector",
        "defaultValue": null,
        "input": "gpu_wattage_avg"
      },
      {
        "key": "gpu_temperature_avg",
        "type": "float",
        "expiry": "5d",
        "processor": "results_selector",
        "defaultValue": null,
        "input": "gpu_temperature_avg"
      }
    ],
    "support_ops": [
      {
        "id": "benchmark",
        "type": "container/run",
        "args": {
          "image": "nosana/llm-benchmark:0.0.2",
          "gpu": true,
          "env": {
            "BASE_URL": "http://%%ops.server.host%%:11434",
            "DURATION": "100",
            "CONCURRENT_USERS": "1",
            "WARMUP_REQUEST_TIMEOUT": "900"
          }
        },
        "execution": {
          "group": "llm-pair"
        },
        "results": {
          "tokens_per_second": "\"users_1_tokens_per_second_mean\":(-?[\\d.]+)",
          "gpu_wattage_avg": "\"users_1_gpu_wattage_avg\":(-?[\\d.]+)",
          "gpu_temperature_avg": "\"users_1_gpu_temperature_avg\":(-?[\\d.]+)"
        }
      }
    ],
    "ops_overrides": {
      "execution": {
        "group": "llm-pair",
        "depends_on": [
          "benchmark"
        ],
        "stop_if_dependent_stops": true
      }
    }
  }
]
